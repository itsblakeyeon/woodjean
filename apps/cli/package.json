{
  "name": "woodjean",
  "version": "1.3.1",
  "description": "우드진 판교점 단체주문 CLI — 회의용 음료 5~30잔 예약 배달",
  "license": "MIT",
  "author": "Blake Yeon",
  "type": "module",
  "bin": {
    "woodjean": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "dev": "node --import tsx src/index.ts",
    "qa-demo": "node --import tsx src/qa-demo.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node build.mjs"
  },
  "//": "all runtime deps are bundled into dist/cli.mjs by esbuild — listed under devDependencies so npm install does not re-fetch them at user install time. @woodjean/shared is also devDependency because esbuild inlines it; the published package is fully self-contained.",
  "dependencies": {},
  "devDependencies": {
    "@clack/prompts": "^0.9.0",
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.10.2",
    "@woodjean/shared": "workspace:*",
    "commander": "^12.1.0",
    "esbuild": "^0.24.0",
    "figlet": "^1.8.0",
    "gradient-string": "^3.0.0",
    "kleur": "^4.1.5",
    "string-width": "^7.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "zod": "^3.24.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "woodjean",
    "coffee",
    "pangyo",
    "group-order",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
