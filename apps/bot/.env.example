# ============================================================================
# Woodjean Bot — 환경변수
# 모든 키는 https://vercel.com/blake-yeon/woodjean-bot/settings/environment-variables 에서 설정.
# ============================================================================

# --- Supabase (필수) ---
# https://supabase.com/dashboard/project/_/settings/api
# 서울 리전(ap-northeast-2) 프로젝트 생성 후 service_role 키 사용 (anon X)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Telegram (필수) ---
# 1. @BotFather에서 봇 생성 → 토큰 발급
# 2. 사장님 본인 계정에서 봇과 1:1 대화 시작 → /start
# 3. https://api.telegram.org/bot<TOKEN>/getUpdates 호출하여 chat.id 확인
# 4. setWebhook 시 secret_token 옵션 권장 (TELEGRAM_WEBHOOK_SECRET)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Setup webhook (배포 후 1회):
# curl "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/setWebhook?url=https://bot.woodjean-pangyo.com/api/telegram/webhook&secret_token=$TELEGRAM_WEBHOOK_SECRET"

# --- Solapi SMS (필수) ---
# https://console.solapi.com 가입 후 API key 발급
# 발신번호는 사전 등록 필요 (사장님 명의 통신증명서 + 사업자등록증)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_FROM_NUMBER=01084842120

# --- Vercel Cron 보호 (선택, 권장) ---
# Vercel Cron이 호출 시 Authorization: Bearer ${CRON_SECRET} 헤더 자동 부착됨
# https://vercel.com/docs/cron-jobs#securing-cron-jobs
CRON_SECRET=

# --- 공개 URL ---
PUBLIC_SITE_URL=https://woodjean-pangyo.com
PUBLIC_BOT_URL=https://bot.woodjean-pangyo.com

# --- Node ---
NODE_ENV=production
